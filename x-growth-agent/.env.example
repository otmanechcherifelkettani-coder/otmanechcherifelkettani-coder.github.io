# X (Twitter) API Credentials
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here
X_BEARER_TOKEN=your_bearer_token_here

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Agent Config
DRY_RUN=false
TIMEZONE=Europe/Madrid
NICHE=personalised supplements, health tech, AI wellness
X_USERNAME=app_supplyn

# Daily X API read budget (max read calls per day — writes always go through)
DAILY_API_BUDGET=40

# Telegram Assistant Mode
# Get your bot token from @BotFather on Telegram
# Get your chat ID by running: python main.py telegram-setup
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# When true: content is sent to Telegram for you to post manually (recommended)
# When false: agent auto-posts to X directly
TELEGRAM_MODE=true
